{
  "manifest_version": 3,
  "name": "Xeton Integration",
  "version": "1.0",
  "description": "Send videos and files to Xeton Download Manager.",
  "permissions": [
    "nativeMessaging",
    "contextMenus",
    "activeTab",
    "downloads",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "cookies",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "action": {
    "default_title": "Download with Xeton",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
